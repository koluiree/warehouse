@page "/requests"
@inject ApiClient Api

<h1 class="page-title">Заявки и выдача</h1>
<p class="page-subtitle">Создание, согласование и выдача по заявкам.</p>

@if (!string.IsNullOrWhiteSpace(Status))
{
    <section class="card" style="@(IsError ? "color:#c62828;border-left:4px solid #c62828;" : "")">@Status</section>
}

<section class="card">
    <h3>Новая заявка</h3>
    <div class="toolbar">
        <select @bind="CreateDepartmentId">
            <option value="0">Отдел</option>
            @foreach (var d in Departments)
            {
                <option value="@d.Id">@d.Name</option>
            }
        </select>
        <select @bind="CreateProductId">
            <option value="0">Продукт</option>
            @foreach (var p in Products)
            {
                <option value="@p.Id">@p.Sku — @p.Name (@p.Unit, @(p.IsInteger ? "целое" : "дробное"), мин. @p.MinQty)</option>
            }
        </select>
        <input type="number" step="@InputStep" placeholder="Количество" @bind="CreateQty" />
        <button class="btn-primary" @onclick="CreateRequest">Создать заявку</button>
    </div>
</section>

<section class="card">
    <h3>Список заявок</h3>
    <div class="toolbar">
        <select @bind="FilterStatus">
            <option>Все статусы</option>
            <option>Submitted</option>
            <option>Approved</option>
            <option>InProgress</option>
            <option>PartiallyIssued</option>
            <option>Issued</option>
            <option>Rejected</option>
            <option>Cancelled</option>
        </select>
        <button @onclick="LoadRequests">Обновить</button>
    </div>

    <table>
        <thead>
            <tr>
                <th>№</th>
                <th>Заявитель</th>
                <th>Продукция</th>
                <th>Статус</th>
                <th>Создана</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in RequestList)
            {
                var isSelected = r.Id == SelectedRequestId;
                <tr style="@(isSelected ? "background:#e3f2fd;" : "")">
                    <td>@r.Id</td>
                    <td>@r.RequesterName</td>
                    <td>
                        @if (r.Items is not null)
                        {
                            @foreach (var it in r.Items)
                            {
                                <div>@it.ProductName: @it.RequestedQty (выдано @it.IssuedQty)</div>
                            }
                        }
                    </td>
                    <td><span class="badge">@r.Status</span></td>
                    <td>@r.CreatedAt.ToLocalTime()</td>
                    <td>
                        <button class="@(isSelected ? "btn-primary" : "")" @onclick="() => SelectRequest(r.Id)">Открыть</button>
                        @if (r.Status == "Submitted")
                        {
                            <button @onclick="() => Approve(r.Id)">Одобрить</button>
                            <button @onclick="() => Reject(r.Id)">Отклонить</button>
                        }
                        @if (r.Status == "Approved")
                        {
                            <button class="btn-primary" @onclick="() => StartIssue(r.Id)">Начать выдачу</button>
                        }
                        @if (r.Status is not "Issued" and not "Cancelled" and not "Rejected")
                        {
                            <button @onclick="() => Cancel(r.Id)">Отменить</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@if (SelectedRequestId > 0)
{
    <section class="card">
        <h3>Детали заявки №@SelectedRequestId</h3>

        @if (SelectedItems.Count == 0)
        {
            <p>Нет позиций.</p>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Продукт</th>
                        <th>Ед.</th>
                        <th>Тип</th>
                        <th>Запрошено</th>
                        <th>Выдано</th>
                        <th>Осталось выдать</th>
                        <th>Выдача</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in SelectedItems)
                    {
                        var product = Products.FirstOrDefault(p => p.Id == item.ProductId);
                        var remaining = item.RequestedQty - item.IssuedQty;
                        var fullyIssued = remaining <= 0;
                        <tr style="@(fullyIssued ? "background:#e8f5e9;" : "")">
                            <td>@(product?.Name ?? $"ID {item.ProductId}")</td>
                            <td>@(product?.Unit ?? "—")</td>
                            <td>@(product is not null ? (product.IsInteger ? "Целое" : "Дробное") : "—")</td>
                            <td>@item.RequestedQty</td>
                            <td>@item.IssuedQty</td>
                            <td style="@(fullyIssued ? "color:green;font-weight:bold;" : "color:#c62828;font-weight:bold;")">
                                @(fullyIssued ? "Выдано полностью" : remaining.ToString())
                            </td>
                            <td>
                                @if (!fullyIssued)
                                {
                                    <div style="display:flex;gap:4px;align-items:center;">
                                        <select @bind="IssueWarehouseId" style="min-width:120px">
                                            <option value="0">Склад</option>
                                            @foreach (var w in Warehouses)
                                            {
                                                <option value="@w.Id">@w.Name</option>
                                            }
                                        </select>
                                        <input type="number"
                                               step="@(product is not null && product.IsInteger ? "1" : "0.001")"
                                               min="@(product?.MinQty ?? 0)"
                                               max="@remaining"
                                               placeholder="Кол-во (макс. @remaining)"
                                               @bind="IssueQty"
                                               style="width:140px" />
                                        <button class="btn-primary" @onclick="() => IssueItem(item.ProductId)">Выдать</button>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    private List<IssueRequestDto> RequestList { get; set; } = [];
    private List<IssueRequestItemDto> SelectedItems { get; set; } = [];
    private List<DepartmentDto> Departments { get; set; } = [];
    private List<ProductDto> Products { get; set; } = [];
    private List<WarehouseDto> Warehouses { get; set; } = [];

    private string FilterStatus { get; set; } = "Все статусы";
    private int CreateDepartmentId { get; set; }
    private int CreateProductId { get; set; }
    private decimal CreateQty { get; set; }
    private long SelectedRequestId { get; set; }
    private int IssueWarehouseId { get; set; }
    private decimal IssueQty { get; set; }
    private string Status { get; set; } = "";
    private bool IsError { get; set; }

    private string InputStep => SelectedProduct is not null && SelectedProduct.IsInteger ? "1" : "0.001";
    private ProductDto? SelectedProduct => Products.FirstOrDefault(p => p.Id == CreateProductId);

    protected override async Task OnInitializedAsync()
    {
        Departments = await Api.GetDepartmentsAsync();
        Products = await Api.GetProductsAsync();
        Warehouses = await Api.GetWarehousesAsync();
        await LoadRequests();
    }

    private async Task LoadRequests()
    {
        var status = FilterStatus == "Все статусы" ? null : FilterStatus;
        RequestList = await Api.GetRequestsAsync(status);
    }

    private void SetStatus(string msg, bool error = false) { Status = msg; IsError = error; }

    private async Task CreateRequest()
    {
        if (CreateProductId <= 0 || CreateQty <= 0)
        {
            SetStatus("Выберите продукт и укажите количество > 0.", true);
            return;
        }

        var prod = SelectedProduct;
        if (prod is not null)
        {
            if (prod.IsInteger && CreateQty != Math.Truncate(CreateQty))
            {
                SetStatus($"Продукт «{prod.Name}» допускает только целое количество.", true);
                return;
            }
            if (prod.MinQty > 0 && CreateQty < prod.MinQty)
            {
                SetStatus($"Минимальное количество для «{prod.Name}»: {prod.MinQty}.", true);
                return;
            }
        }

        var err = await Api.CreateRequestAsync(new CreateIssueRequestRequest(
            CreateDepartmentId,
            "Создано пользователем",
            [new CreateIssueRequestItemRequest(CreateProductId, CreateQty)]));

        if (err is null)
            SetStatus("Заявка создана.");
        else
            SetStatus($"Ошибка: {err}", true);

        await LoadRequests();
    }

    private async Task SelectRequest(long id)
    {
        SelectedRequestId = id;
        SelectedItems = await Api.GetRequestItemsAsync(id);
        IssueQty = 0;
    }

    private async Task Approve(long id)
    {
        var err = await Api.ApproveRequestAsync(id, "Одобрено");
        if (err is null) SetStatus("Заявка одобрена."); else SetStatus($"Ошибка: {err}", true);
        await LoadRequests();
    }

    private async Task Reject(long id)
    {
        var err = await Api.RejectRequestAsync(id, "Отклонено");
        if (err is null) SetStatus("Заявка отклонена."); else SetStatus($"Ошибка: {err}", true);
        await LoadRequests();
    }

    private async Task StartIssue(long id)
    {
        var err = await Api.StartIssueAsync(id);
        if (err is null) SetStatus("Выдача начата."); else SetStatus($"Ошибка: {err}", true);
        await LoadRequests();
        if (SelectedRequestId == id)
            SelectedItems = await Api.GetRequestItemsAsync(id);
    }

    private async Task Cancel(long id)
    {
        var err = await Api.CancelRequestAsync(id, "Отменено");
        if (err is null) SetStatus("Заявка отменена."); else SetStatus($"Ошибка: {err}", true);
        await LoadRequests();
    }

    private async Task IssueItem(int productId)
    {
        if (IssueWarehouseId <= 0)
        {
            SetStatus("Выберите склад для выдачи.", true);
            return;
        }
        if (IssueQty <= 0)
        {
            SetStatus("Укажите количество для выдачи > 0.", true);
            return;
        }

        var err = await Api.IssueItemAsync(SelectedRequestId,
            new IssueItemRequest(IssueWarehouseId, productId, IssueQty, "Выдано по заявке"));

        if (err is null)
            SetStatus("Позиция выдана.");
        else
            SetStatus($"Ошибка выдачи: {err}", true);

        SelectedItems = await Api.GetRequestItemsAsync(SelectedRequestId);
        IssueQty = 0;
        await LoadRequests();
    }
}
